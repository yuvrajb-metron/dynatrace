# Extension Configuration Template
# This file shows the expected configuration structure for your extension
# Replace the TODO sections with your specific configuration requirements

{
  "connection": {
    "dynatraceUrl": "https://your-dynatrace-environment.com",
    "dynatraceAccessToken": "your-dynatrace-api-token",
    "ingestAsLogs": false,
    
    # TODO: Replace with your external API connection details
    "externalApiUrl": "https://api.your-external-service.com",
    "apiKey": "your-external-api-key",
    "apiSecret": "your-external-api-secret",
    
    # TODO: Add additional connection parameters as needed
    "timeout": 30,
    "retries": 3,
    "verify_ssl": true
  },
  
  "products": {
    # TODO: Replace with your specific data types/products
    "dataType1": true,
    "dataType2": false,
    "auditLogs": true,
    "vulnerabilities": true,
    "assets": true
  },
  
  "advancedOptions": {
    "debugLogs": false,
    
    # TODO: Configure collection frequencies (in hours)
    "collectionFrequency": 1,
    "firstTimeFetchWindow": 24,
    
    # TODO: Add specific options for your data types
    "includeInfoLevel": true,
    "maxRecordsPerBatch": 1000,
    "enableAssetEnrichment": true,
    
    # TODO: Add filtering options
    "severityFilter": ["CRITICAL", "HIGH", "MEDIUM"],
    "statusFilter": ["ACTIVE", "OPEN"],
    
    # TODO: Add custom field mappings
    "customFieldMappings": {
      "external_field_1": "dt.custom.field1",
      "external_field_2": "dt.custom.field2"
    }
  }
}
