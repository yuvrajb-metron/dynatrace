{
    "version": 20,
    "variables": [
        {
            "version": 2,
            "key": "TenantURL",
            "type": "query",
            "visible": true,
            "editable": true,
            "input": "timeseries { avg(sonarqube.code.lines) }, by: { tenant }\n| fields tenant\n| dedup tenant\n| sort tenant asc\n| append [data record(tenant=\"None\")]",
            "multiple": true,
            "defaultValue": [
                "3420b2ac-f1cf-4b24-b62d-61ba1ba8ed05*"
            ]
        },
        {
            "version": 2,
            "key": "Projects",
            "type": "query",
            "visible": true,
            "editable": true,
            "input": "timeseries { avg(sonarqube.code.lines) }, by: { project }, \nfilter:{in(tenant,$TenantURL)}\n| fields project\n| dedup project\n| sort project asc\n| append [data record(project=\"None\")]",
            "multiple": true,
            "defaultValue": [
                "3420b2ac-f1cf-4b24-b62d-61ba1ba8ed05*"
            ]
        }
    ],
    "tiles": {
        "0": {
            "title": "",
            "type": "data",
            "query": "fetch events\n| filter event.kind == \"SDLC_EVENT\"\n     AND event.status == \"finished\"\n     AND event.provider == \"SonarQube\"\n| filter in(sonarqube.project.id, $Projects)\n    AND in(sonarqube.tenant,$TenantURL)\n| fieldsAdd end_time=toTimestamp(end_time), start_time=toTimestamp(start_time)\n| fieldsAdd joinField=concat(toString(end_time),\":\",sonarqube.project.id)\n| join [\n    fetch security.events\n  | filter event.provider == \"SonarQube\"\n  | filter event.type == \"VULNERABILITY_SCAN\"\n  | filter in(sonarqube.project.id, $Projects)\n    AND in(sonarqube.tenant,$TenantURL)\n  | fieldsAdd joinField=concat(scan.time.completed,\":\",sonarqube.project.id)\n], on:{joinField}, \nfields:{\n  security.artifact.id=artifact.id\n}\n| fieldsAdd `Quality gate`=if(task.outcome==\"Success\",\"Passed\", else:\"Failed\")\n| summarize \nby: {    Scan=end_time, \n         Project=sonarqube.project.id,\n         `Quality gate`,\n         Description=event.description\n}, {`Scanned files`=countDistinctExact(security.artifact.id)}\n| dedup Scan\n| sort Scan desc",
            "visualization": "table",
            "visualizationSettings": {
                "table": {
                    "columnOrder": [
                        "[\"Scan\"]",
                        "[\"Quality gate\"]",
                        "[\"Project\"]",
                        "[\"Description\"]",
                        "[\"Scanned files\"]"
                    ],
                    "hideColumnsForLargeResults": false,
                    "columnWidths": {
                        "[\"Project\"]": 469
                    }
                },
                "thresholds": [
                    {
                        "id": 1,
                        "field": "Quality gate",
                        "title": "",
                        "isEnabled": true,
                        "rules": [
                            {
                                "id": 0,
                                "color": {
                                    "Default": "var(--dt-colors-charts-status-ideal-default, #2f6862)"
                                },
                                "comparator": "=",
                                "label": "",
                                "value": "Passed"
                            },
                            {
                                "id": 2,
                                "color": {
                                    "Default": "var(--dt-colors-charts-status-critical-default, #c62239)"
                                },
                                "comparator": "=",
                                "label": "",
                                "value": "Failed"
                            }
                        ]
                    }
                ]
            },
            "querySettings": {
                "maxResultRecords": 1000,
                "defaultScanLimitGbytes": 500,
                "maxResultMegaBytes": 1,
                "defaultSamplingRatio": 10,
                "enableSampling": false
            },
            "davis": {
                "enabled": false,
                "davisVisualization": {
                    "isAvailable": true
                }
            }
        },
        "1": {
