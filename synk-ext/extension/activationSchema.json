{
  "$schema": "https://artifactory.lab.dynatrace.org/artifactory/ruxit-cluster-release-local/com/dynatrace/configuration/configuration-core-schema-resources/0.615.0.20240306130838/configuration-core-schema-resources-0.615.0.20240306130838-sources.jar!/1/schema_strict_static.json",
  "enums": {
    "severity-enum": {
      "displayName": "Minimum severity level",
      "type": "enum",
      "items": [
        { 
          "value": "info",
          "displayName": "Info"
        },
        {
          "value": "low",
          "displayName": "Low"
        },
        {
          "value": "medium",
          "displayName": "Medium"
        },
        {
          "value": "high",
          "displayName": "High"
        },
        {
          "value": "critical",
          "displayName": "Critical"
        }
      ]
    }
  },
  "types": {
    "pythonRemote": {
      "type": "object",
      "properties": {
        "products": {
          "displayName": "Choose data to bring in:",
          "nullable": false,
          "type": {
            "$ref": "#/types/products"
          }
        },
        "orgs": {
          "displayName": "Choose Snyk organizations to integrate with:",
          "nullable": false,
          "type": {
            "$ref": "#/types/orgs"
          }
        },
        "connection": {
          "displayName": "Connection",
          "description": "For more information, see [Authentication for API](https://docs.snyk.io/snyk-api/rest-api/authentication-for-api)",
          "nullable": false,
          "type": {
            "$ref": "#/types/connection"
          }
        },
        "advancedOptions": {
          "uiCustomization": {
            "expandable": {
              "sections": [
                {
                  "displayName": "Advanced options",
                  "properties": [
                    "minimumSeverityLevel",
                    "projectOrigins",
                    "firstTimeFetchWindow",
                    "vulnsFetchFrequency",
                    "auditFetchFrequency",
                    "dynatraceProxy",
                    "debugLogs"
                  ]
                }
              ]
            }
          },
          "displayName": "Advanced options",
          "nullable": false,
          "type": {
            "$ref": "#/types/advancedOptions"
          }
        }
      }
    },
    "products": {
      "displayName": "Choose data to bring in:",
      "description": "",
      "summaryPattern": "",
      "type": "object",
      "properties": {
        "fetchEvents": {
          "displayName": "Fetch vulnerability findings and scan events",
          "type": "boolean",
          "nullable": false,
          "default": true
        },
        "fetchAuditLogs": {
          "displayName": "Fetch audit logs",
          "type": "boolean",
          "nullable": false,
          "default": true
        }
      }
    },
    "orgs": {
      "displayName": "Choose Snyk organizations to integrate with:",
      "description": "",
      "summaryPattern": "",
      "type": "object",
      "properties": {
        "allOrgs": {
          "displayName": "All organizations",
          "description": "Ingest security findings from all organizations accessible with the provided credentials or specify a list of organizations to integrate with.",
          "type": "boolean",
          "nullable": false,
          "default": false
        },
        "orgList": {
          "displayName": "Organizations",
          "type": "list",
          "nullable": false,
          "precondition": {
            "type": "EQUALS",
            "expectedValue": false,
            "property": "allOrgs"
          },
          "items": {
            "type": "text",
            "displayName": "Organization name",
            "metadata": {
              "placeholder": "example_organization"
            }
          },
          "metadata": {
            "addItemButton": "Add organization"
          }
        }
      }
    },
    "connection": {
      "displayName": "Connection",
      "summaryPattern": "",
      "type": "object",
      "properties": {
        "snykUrl": {
          "displayName": "Snyk base URL",
          "description": "Base URL for your Snyk region. For more information, see [Snyk's region URLs](https://docs.snyk.io/working-with-snyk/regional-hosting-and-data-residency#available-snyk-regions).",
          "type": "text",
          "nullable": false,
          "default": "https://app.snyk.io/",
          "metadata": {
            "placeholder": "Provide your Snyk base URL"
          },
          "constraints": [
            {
              "type": "LENGTH",
              "minLength": 1,
              "maxLength": 500
            }
          ]
        },
        "apiToken": {
          "displayName": "Snyk API token",
          "type": "secret",
          "nullable": false,
          "default": "",
          "metadata": {
            "placeholder": "Snyk API token with sufficient privileges"
          },
          "constraints": [
            {
              "type": "LENGTH",
              "minLength": 1,
              "maxLength": 500
            }
          ]
        },
        "dynatraceUrl": {
          "displayName": "Dynatrace security events endpoint",
          "description": "For example: `https://env12345.live.dynatrace.com/platform/ingest/v1/security.events`. For more information, see [Security events ingest](https://docs.dynatrace.com/docs/secure/threat-observability/security-events-ingest)",
          "type": "text",
          "nullable": false,
          "default": "",
          "metadata": {
            "placeholder": "Provide an OpenPipeline endpoint for security events ingest"
          },
          "constraints": [
            {
              "type": "LENGTH",
              "minLength": 1,
              "maxLength": 500
            }
          ]
        },
        "dynatraceAccessToken": {
          "displayName": "Dynatrace access token",
          "description": "Should have the `openpipeline.events_security` scope. For more information, see [Generate an access token](https://docs.dynatrace.com/docs/manage/identity-access-management/access-tokens-and-oauth-clients/access-tokens#create-api-token)",
          "type": "secret",
          "nullable": false,
          "default": "",
          "metadata": {
            "placeholder": "Provide an access token with the openpipeline.events_security scope"
          },
          "constraints": [
            {
              "type": "LENGTH",
              "minLength": 1,
              "maxLength": 500
            }
          ]
        }
      }
    },
    "advancedOptions": {
      "type": "object",
      "displayName": "Advanced options",
      "summaryPattern": "",
      "properties": {
        "minimumSeverityLevel": {
          "displayName": "Minimum severity level",
          "type":{
            "$ref": "#/enums/severity-enum"
          },
          "description": "The minimum issue severity level to ingest. Only issues of this severity level or above will be ingested. If left empty, all issues will be ingested.",
          "nullable": true,
          "maxObjects": 1
        },
        "projectOrigins": {
          "displayName": "Project origins filter",
          "type": "text",
          "description": "Comma-separated list of the project origins to filter by. Only projects which match any of these origins will be collected. If left empty all projects will be collected.\n\nFor example, `cli,ecr,docker-hub` would ingest data for all projects which either have origin `cli`, `ecr` or `docker-hub`.",
          "nullable": true,
          "maxObjects": 1
        },
        "firstTimeFetchWindow": {
          "displayName": "First export time window",
          "description": "The amount of time to look back for the first export. Note that the first export runs every time the extension is restarted.",
          "type": "float",
          "nullable": false,
          "default": 12,
          "metadata": {
            "suffix": "hours"
          }
        },
        "vulnsFetchFrequency": {
          "displayName": "Vulnerability management ingest frequency",
          "description": "The integration will fetch vulnerability findings and scan events periodically using the specified time period. Defaults to 1 hour.",
          "type": "float",
          "nullable": true,
          "metadata": {
            "suffix": "hours"
          }
        },
        "auditFetchFrequency": {
          "displayName": "Audit log ingest frequency",
          "description": "The integration will fetch audit logs periodically using the specified time period. Defaults to 1 hour.",
          "type": "float",
          "nullable": true,
          "metadata": {
            "suffix": "hours"
          }
        },
        "dynatraceProxy": {
          "displayName": "Proxy",
          "documentation": "\r\nIf your ActiveGate requires a proxy to connect to your Dynatrace environment, please provide it here.",
          "nullable": true,
          "type": {
            "$ref": "#/types/proxy"
          },
          "metaData": {
            "addItemButton": "Define proxy"
          }
        },
        "debugLogs": {
          "displayName": "Enable extension debug logs",
          "description": "\r\nPlease provide feedback to us about this extension [here](https://dt-url.net/93031vt).",
          "type": "boolean",
          "nullable": false,
          "default": false
        }
      }
    },
    "proxy": {
      "type": "object",
      "displayName": "Proxy",
      "summaryPattern": "Proxy {address}",
      "properties": {
        "address": {
          "type": "text",
          "displayName": "Address",
          "description": "Proxy address, for example: \n\n* http://proxy.example.com:8080\n* https://proxy.example.com:9091",
          "nullable": false,
          "default": "",
          "constraints": [
            {
              "type": "NOT_EMPTY"
            }
          ]
        },
        "username": {
          "type": "text",
          "displayName": "Proxy username",
          "nullable": true
        },
        "password": {
          "type": "secret",
          "displayName": "Proxy password",
          "nullable": true
        }
      }
    }
  },
  "dynatrace": "1",
  "description": "Snyk integration",
  "schemaId": "python-extension.activation",
  "displayName": "Snyk integration",
  "ownerProductManagement": "dynatrace",
  "ownerDevelopment": "dynatrace",
  "maturity": "GENERAL_AVAILABILITY",
  "allowedScopes": [
    "tenant"
  ],
  "multiObject": false,
  "properties": {
    "pythonRemote": {
      "displayName": "Python Remote Extension",
      "type": {
        "$ref": "#/types/pythonRemote"
      }
    }
  }
}